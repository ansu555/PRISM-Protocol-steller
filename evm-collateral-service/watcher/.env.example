# PRISM app base URL (where the oracle API lives)
PRISM_API_BASE_URL=http://localhost:3000

# Ethereum Sepolia
ETH_SEPOLIA_RPC_URL=https://sepolia.drpc.org
ETH_SEPOLIA_VAULT_ADDRESS=0xd0130A053820F292B1807C246a1074443E491fcb

# Base Sepolia (uncomment when vault deployed there)
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.drpc.org
# BASE_SEPOLIA_VAULT_ADDRESS=0x...

# Base Mainnet (uncomment when live)
# BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# BASE_MAINNET_VAULT_ADDRESS=0x...

# Arbitrum Mainnet (uncomment when live)
# ARB_MAINNET_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
# ARB_MAINNET_VAULT_ADDRESS=0x...

# Ethereum Mainnet (uncomment when live)
# ETH_MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# ETH_MAINNET_VAULT_ADDRESS=0x...
