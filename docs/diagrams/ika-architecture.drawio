        <mxCell id="gate" value="Disburse handler: require!(collateral.status == Locked)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#1A1A1A;strokeWidth=1.5;fontSize=11;fontStyle=1" vertex="1" parent="1">
