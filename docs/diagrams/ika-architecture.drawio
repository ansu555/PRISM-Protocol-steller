        <mxCell id="snapshot" value="State at end of Phase 1:&#10;BTC sits on Bitcoin. dWallet metadata on Sui. Loan record on Solana. Key material split across IKA validators - borrower cannot move BTC unilaterally." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F5F5F5;strokeColor=#999999;fontSize=11;fontStyle=2;align=center;verticalAlign=middle" vertex="1" parent="1">
          <mxGeometry x="380" y="320" width="1120" height="46" as="geometry" />
        </mxCell>

