# ── Stellar / Soroban ──────────────────────────────────────────────────────────

# Deployed contract IDs (56-char Stellar StrKey, CXX...)
NEXT_PUBLIC_PRISM_CORE_CONTRACT_ID=
NEXT_PUBLIC_USDC_CONTRACT_ID=
NEXT_PUBLIC_SOROSWAP_ROUTER_ID=
NEXT_PUBLIC_SOROSWAP_FACTORY_ID=
NEXT_PUBLIC_REFLECTOR_CONTRACT_ID=

# Network
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# PTUSDC asset (testnet — issuer mints freely for demo)
NEXT_PUBLIC_USDC_ASSET_CODE=PTUSDC
NEXT_PUBLIC_USDC_ASSET_ISSUER=

# Demo state
NEXT_PUBLIC_VAULT_ID=0
NEXT_PUBLIC_ADMIN_ADDRESS=

# Public app URL (set to tunnel/deployed URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── EVM Cross-Chain Collateral (Ethereum / Base / Arbitrum) ──────────────────
# Deployed PrismCollateralVault.sol address on the target EVM chain
EVM_VAULT_ADDRESS=0xd0130A053820F292B1807C246a1074443E491fcb   # Ethereum Sepolia testnet

# Alchemy (or any JSON-RPC) endpoint for the EVM chain
# Free tier: https://alchemy.com — supports eth_getLogs (required for oracle watcher)
EVM_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Admin wallet that owns the vault (Gnosis Safe on mainnet, single EOA on testnet)
# Must match the `admin` arg passed to PrismCollateralVault constructor at deploy time
EVM_DEPLOYER_PRIVATE_KEY=0x...     # testnet only — use Gnosis Safe on mainnet
EVM_TREASURY_ADDRESS=0x...          # receives collateral on liquidation

# Block explorer for the EVM chain (used in admin panel links)
EVM_EXPLORER_URL=https://sepolia.etherscan.io

# ── MoneyGram Access (SEP-24 fiat ramp) ───────────────────────────────────────

NEXT_PUBLIC_MONEYGRAM_ANCHOR_DOMAIN=stellar.moneygram.com
NEXT_PUBLIC_MONEYGRAM_ASSET_CODE=USDC

# ── Admin / deployer secret (server-side only — never NEXT_PUBLIC_) ───────────
# Stellar admin keypair — used for init_config, init_vault, init_loan, disburse_loan
# and as the relayer for verify_collateral / release_collateral.
# Generate: stellar keys generate prism-admin && stellar keys show prism-admin --show-secret
ADMIN_SECRET_SEED=S...

# SAC admin — only needed if the USDC issuer keypair differs from ADMIN_SECRET_SEED
# (separate account that minted the PTUSDC asset)
USDC_ADMIN_SECRET_SEED=S...

# ── Oracle signer seeds (server-side only — never NEXT_PUBLIC_) ────────────────
# Generate: openssl rand -hex 32

COLLATERAL_ORACLE_SEED=                     # primary Ed25519 seed (hex)
COLLATERAL_ORACLE_SEED_DEV=                 # fallback for local dev
COLLATERAL_ORACLE_SEED_NEXT=                # pre-rotated next key
COLLATERAL_ORACLE_ACTIVE_KEY_ID=primary
COLLATERAL_ORACLE_PRIMARY_KEY_ID=primary
COLLATERAL_ORACLE_NEXT_KEY_ID=next
COLLATERAL_ORACLE_RATE_LIMIT_PER_MINUTE=60

ENCRYPT_ORACLE_SECRET_SEED=
ENCRYPT_ORACLE_SECRET_SEED_DEV=
ENCRYPT_ORACLE_SECRET_SEED_NEXT=
ENCRYPT_ORACLE_ACTIVE_KEY_ID=primary
ENCRYPT_ORACLE_PRIMARY_KEY_ID=primary
ENCRYPT_ORACLE_NEXT_KEY_ID=next
ENCRYPT_ORACLE_RATE_LIMIT_PER_MINUTE=60

CLOAK_ORACLE_SEED=
CLOAK_ORACLE_SEED_DEV=
CLOAK_ORACLE_SEED_NEXT=
CLOAK_ORACLE_ACTIVE_KEY_ID=primary
CLOAK_ORACLE_PRIMARY_KEY_ID=primary
CLOAK_ORACLE_NEXT_KEY_ID=next
CLOAK_ORACLE_RATE_LIMIT_PER_MINUTE=60

ORACLE_RATE_LIMIT_WINDOW_SECONDS=60

# ── Database ───────────────────────────────────────────────────────────────────
# Postgres connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL="postgres://user:password@host:5432/prism?sslmode=require"

# Supabase (if using Supabase for DB + auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
