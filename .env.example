# ── Stellar / Soroban ──────────────────────────────────────────────────────────

# Deployed contract IDs (56-char Stellar StrKey, CXX...)
NEXT_PUBLIC_PRISM_CORE_CONTRACT_ID=
NEXT_PUBLIC_USDC_CONTRACT_ID=
NEXT_PUBLIC_SOROSWAP_ROUTER_ID=
NEXT_PUBLIC_SOROSWAP_FACTORY_ID=
NEXT_PUBLIC_REFLECTOR_CONTRACT_ID=

# Network
NEXT_PUBLIC_STELLAR_NETWORK=testnet
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_HORIZON_URL=https://horizon-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Demo state
NEXT_PUBLIC_VAULT_ID=0
NEXT_PUBLIC_ADMIN_ADDRESS=

# Public app URL (set to tunnel URL during live demo)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── IKA Cross-Chain Collateral (BTC / ETH via MPC dWallet) ──────────────────

# IKA API base URL — defaults to https://api.ika.xyz (mainnet)
NEXT_PUBLIC_IKA_API_URL=https://api.ika.xyz

# IKA oracle Ed25519 pubkey hex (32 bytes, 64 hex chars).
# Must match the pubkey registered in prism-core's oracle_allowlist:
#   bash soroban/scripts/oracle-allowlist.sh add <this value>
# Retrieve from: https://api.ika.xyz/v1/oracle/pubkey
NEXT_PUBLIC_IKA_ORACLE_PUBKEY=

# ── MoneyGram Access (SEP-24 fiat ramp) ───────────────────────────────────────

NEXT_PUBLIC_MONEYGRAM_ANCHOR_DOMAIN=stellar.moneygram.com
NEXT_PUBLIC_MONEYGRAM_ASSET_CODE=USDC

# ── Admin / deployer secret (server-side only — never NEXT_PUBLIC_) ───────────
# The deployer's Stellar secret key (S...). Required for the admin UI buttons:
#   "Initialize Vault" and "Fund Identities" on the simulation dashboard.
# Retrieve it with: stellar keys show prism-admin --show-secret
ADMIN_SECRET_SEED=

# ── Oracle signer seeds (server-side only — never NEXT_PUBLIC_) ────────────────

COLLATERAL_ORACLE_SEED=
COLLATERAL_ORACLE_SEED_DEV=
COLLATERAL_ORACLE_SEED_NEXT=
COLLATERAL_ORACLE_ACTIVE_KEY_ID=primary
COLLATERAL_ORACLE_PRIMARY_KEY_ID=primary
COLLATERAL_ORACLE_NEXT_KEY_ID=next
COLLATERAL_ORACLE_RATE_LIMIT_PER_MINUTE=60

ENCRYPT_ORACLE_SECRET_SEED=
ENCRYPT_ORACLE_SECRET_SEED_DEV=
ENCRYPT_ORACLE_SECRET_SEED_NEXT=
ENCRYPT_ORACLE_ACTIVE_KEY_ID=primary
ENCRYPT_ORACLE_PRIMARY_KEY_ID=primary
ENCRYPT_ORACLE_NEXT_KEY_ID=next
ENCRYPT_ORACLE_RATE_LIMIT_PER_MINUTE=60

CLOAK_ORACLE_SEED=
CLOAK_ORACLE_SEED_DEV=
CLOAK_ORACLE_SEED_NEXT=
CLOAK_ORACLE_ACTIVE_KEY_ID=primary
CLOAK_ORACLE_PRIMARY_KEY_ID=primary
CLOAK_ORACLE_NEXT_KEY_ID=next
CLOAK_ORACLE_RATE_LIMIT_PER_MINUTE=60

ORACLE_RATE_LIMIT_WINDOW_SECONDS=60

# ── Database ───────────────────────────────────────────────────────────────────

DATABASE_URL="postgres://user:password@host:5432/prism?sslmode=require"
